<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumina.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Lumina.Views.Pages.HabitView"
             x:DataType="vm:HabitViewModel">    

    <Border Padding="10" BorderThickness="1" 
            BorderBrush="#FFFFFF" CornerRadius="15" Background="{Binding BackgroundColor}">
        <Grid RowDefinitions="*, *, *, *" RowSpacing="2" ColumnDefinitions="*, Auto" ColumnSpacing="5"> 
            <TextBlock Grid.Column="0" Text="{Binding Title}" 
                       Grid.Row="0" Foreground="White" FontSize="15"/>
            <TextBlock Grid.Column="0" Text="Описание:" Grid.Row="1" Foreground="White" FontSize="12" />
            
            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="4" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔥" FontSize="20" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Streak}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="Orange"/>
            </StackPanel>
            
            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Description}" Grid.Row="2" 
                       Foreground="White" FontSize="12" TextWrapping="Wrap" />
            <Button Grid.Column="0" Grid.Row="3" Content="Подробнее" Command="{Binding OpenModalCommand}"/>
        </Grid>    
    </Border>
    
</UserControl>