<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumina.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Lumina.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Border Background="#1E1A3D" Padding="10">
        <Grid RowDefinitions="*,*" ColumnDefinitions="*,*" >
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                <TextBlock Text="Количество колонок на вкладке дня:" Foreground="White" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding AllowedValues}" 
                          SelectedItem="{Binding Hour}" 
                          HorizontalAlignment="Stretch" />
            </StackPanel>
        </Grid>
    </Border>
    
</UserControl>